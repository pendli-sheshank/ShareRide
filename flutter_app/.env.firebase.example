# Firebase Configuration for Phase 5 Monitoring & Feature Flags

# Firebase Project Configuration
# Get these from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=shareride-production
FIREBASE_PROJECT_NUMBER=123456789012

# Firebase Apps (iOS and Android)
# Each platform has its own app in Firebase Console
FIREBASE_IOS_APP_ID=1:123456789012:ios:abcdef1234567890
FIREBASE_ANDROID_APP_ID=1:123456789012:android:abcdef1234567890

# Firebase API Key
# This is the public API key (safe to include in code)
FIREBASE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxx

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=shareride-production.firebaseapp.com

# Firebase Database URL (if using Realtime Database)
FIREBASE_DATABASE_URL=https://shareride-production.firebaseio.com

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=shareride-production.appspot.com

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789012

# Sentry Configuration
# Get from: https://sentry.io/settings/your-org/projects/shareride/
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACE_SAMPLE_RATE=0.8

# Feature Flags (Firebase Remote Config)
# These are overridden by Firebase Remote Config at runtime
# But set defaults here for offline capability
FLUTTER_ROLLOUT_PERCENTAGE=0
USE_FLUTTER_BROWSE_RIDES=false
USE_FLUTTER_MY_RIDES=false
USE_FLUTTER_POST_RIDE=false
USE_FLUTTER_CHAT=false
USE_FLUTTER_PROFILE=false

# Performance Monitoring Thresholds
MAX_STARTUP_TIME_MS=3000
MAX_QUERY_TIME_MS=2000
MAX_MESSAGE_LATENCY_MS=500
MAX_MEMORY_MB=200

# Monitoring Flags
ENABLE_CRASH_REPORTING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ANALYTICS=true

# Firebase App Distribution (Beta Releases)
# Get from: Firebase Console → App Distribution
FIREBASE_APP_DISTRIBUTION_ID=1:123456789012:android:abcdef1234567890
FIREBASE_TESTERS_EMAIL=beta-testers@example.com

# Google Play Store Configuration
GOOGLE_PLAY_PACKAGE_NAME=com.shareride.app
GOOGLE_PLAY_STORE_ID=AIzaSyDxxxxxxxxxxxxxxxxxxx

# Apple App Store Configuration
APPLE_BUNDLE_ID=com.shareride.app
APPLE_TEAM_ID=ABCDE12345
